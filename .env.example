# Copy this file to ".env" (same folder as composer.json) and fill in real values.
# NEVER commit the real .env file to git.

APP_ENV=local
APP_URL=http://localhost/semas/public
APP_KEY=replace-with-32-plus-random-bytes-base64

DB_HOST=127.0.0.1
DB_NAME=semas
DB_USER=root
DB_PASS=

# --- Mail: choose ONE block and comment out the others -----------------

# Gmail (requires a Google "App Password", not your normal Gmail password:
# Google Account -> Security -> 2-Step Verification -> App passwords)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_address@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM_ADDRESS=your_address@gmail.com
MAIL_FROM_NAME=University of Kigali - SEMAS

# Outlook / Office365 (uncomment and use instead of Gmail block above)
# MAIL_HOST=smtp.office365.com
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=your_address@outlook.com
# MAIL_PASSWORD=your_outlook_password_or_app_password
# MAIL_FROM_ADDRESS=your_address@outlook.com
# MAIL_FROM_NAME=University of Kigali - SEMAS

# University mail server (uncomment and use instead, ask your IT/mail admin for these)
# MAIL_HOST=mail.uok.ac.rw
# MAIL_PORT=587
# MAIL_ENCRYPTION=tls
# MAIL_USERNAME=semas@uok.ac.rw
# MAIL_PASSWORD=your_university_mailbox_password
# MAIL_FROM_ADDRESS=semas@uok.ac.rw
# MAIL_FROM_NAME=University of Kigali - SEMAS

# --- SMS: choose ONE provider -------------------------------------------
# Use "vonage" (recommended) or "africastalking"
SMS_PROVIDER=vonage

# Vonage — get credentials at dashboard.nexmo.com (API Settings)
VONAGE_API_KEY=your_vonage_api_key
VONAGE_API_SECRET=your_vonage_api_secret
VONAGE_FROM=your_sms_sender_number_or_alphaid      # e.g. 250786408274 or SEMAS
VONAGE_WHATSAPP_FROM=your_whatsapp_business_number # WhatsApp Business number (digits only, no +)

# Africa's Talking (uncomment to use instead)
# AT_USERNAME=your_at_username
# AT_API_KEY=your_at_api_key
# AT_SHORTCODE=SEMAS
