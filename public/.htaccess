Options -Indexes
RewriteEngine On

# Redirect /page.php → /page (GET only — redirecting POST/AJAX requests would
# turn them into GETs and silently drop the request body).
# THE_REQUEST is the original HTTP request line — never changes on internal rewrites,
# so this rule only fires on real browser requests, not after the internal rewrite below.
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \.php[\s?]
RewriteCond %{REQUEST_URI} ^(.*?)\.php$
RewriteRule ^ %1 [R=301,L,NE]

# Internally serve /page as /page.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)$ $1.php [L]
