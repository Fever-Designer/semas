Options -Indexes
RewriteEngine On

# Redirect /page.php → /page (GET only — redirecting POST/AJAX requests would
# turn them into GETs and silently drop the request body).
# THE_REQUEST is the original HTTP request line — never changes on internal rewrites,
# so this rule only fires on real browser requests, not after the internal rewrite below.
RewriteCond %{REQUEST_METHOD} GET
RewriteCond %{THE_REQUEST} \.php[\s?]
RewriteCond %{REQUEST_URI} ^(.*?)\.php$
RewriteRule ^ %1 [R=301,L,NE]

# Internally serve /page as /page.php — guarded against re-matching its own
# output (without this, a URI whose .php target ALSO doesn't exist gets
# rewritten to page.php, which still isn't -f, so the rule fires again and
# appends another .php forever, until Apache's internal-redirect limit aborts
# the request with a 500 instead of a clean 404).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !\.php$
RewriteRule ^(.+)$ $1.php [L]
